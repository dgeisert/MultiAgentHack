# Copy to .env and fill in. With NO keys set, Loreweaver runs fully mocked and
# still produces a real, playable feed + audio for the demo.

# --- Creative core (set all three to leave mock mode) ---
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
TAVILY_API_KEY=

# --- Model selection (optional overrides) ---
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Publishing (optional; stubbed if unset) ---
PODCAST_HOST_API_KEY=
YOUTUBE_CLIENT_SECRETS=
PUBLIC_BASE_URL=http://localhost:8000

# --- Knobs ---
CHAPTER_MIN_WORDS=900
CHAPTER_MAX_WORDS=2200
LOREWEAVER_MAX_RETRIES=2
LOREWEAVER_CRON=0 9 * * *

# Force mock mode even if keys are present (handy for offline dev):
# LOREWEAVER_MOCK=1

# Demo safety net: if a LIVE API call fails, degrade to mock output for that
# step instead of crashing the whole run.
# LOREWEAVER_FALLBACK_MOCK=1
